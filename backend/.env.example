# ==========================
# FastAPI service
# ==========================
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ==========================
# Aliyun Model Studio (DashScope) OpenAI-compatible config
# 参考：北京地域 https://dashscope.aliyuncs.com/compatible-mode/v1
# 你也可以替换为新加坡或美国地域的兼容地址
# ==========================
LLM_MODEL_ID=qwen3-max
LLM_API_KEY=
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_TIMEOUT=60
LLM_ENABLE_THINKING=false

# ==========================
# GNSS navigation defaults
# ==========================
DEFAULT_BASELINE_LENGTH_M=1.20
DEFAULT_CANDIDATE_COUNT=5
MAX_RETRY_ROUNDS=2

# ==========================
# Optional: AMap reverse geocoding for semantic location description
# 申请 Web 服务 Key 后填入。未配置时不影响核心功能。
# ==========================
AMAP_WEB_KEY=

# 高德地图前端 JS API（轨迹展示与回放）
AMAP_JS_KEY=
AMAP_SECURITY_JS_CODE=
